@using OpenJustice.Reader.Models.Cases

<div class="sensitive-content-gate">
    @if (!IsContentVisible)
    {
        <div class="alert alert-warning" role="alert">
            <div class="d-flex align-items-start">
                <div class="me-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" 
                         class="bi bi-exclamation-triangle text-warning" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                </div>
                <div>
                    <h5 class="alert-heading">Conteúdo Sensível</h5>
                    <p class="mb-0">
                        Este caso contém <strong>material sensível</strong> que pode incluir descrições 
                        de violência, abuse, ou outros conteúdos que possam ser perturbadores para alguns leitores.
                    </p>
                    <hr>
                    <p class="mb-0 small text-muted">
                        <strong>Ao prosseguir, você reconhece que:</strong>
                    </p>
                    <ul class="mb-0 small">
                        <li>Este material é fornecido apenas para fins educacionais e de pesquisa</li>
                        <li>Você理解了 a natureza sensível do conteúdo</li>
                        <li>Você Assume a responsabilidade pelo seu acesso a este material</li>
                    </ul>
                    <hr>
                    <button class="btn btn-warning" @onclick="ShowContent">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" 
                             class="bi bi-eye me-1" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                        Eu entendo, mostre o conteúdo
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        @ChildContent
    }
</div>

@code {
    [Parameter]
    public bool IsSensitive { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool IsContentVisible { get; set; }

    protected override void OnParametersSet()
    {
        // Reset visibility when the sensitive flag changes
        if (!IsSensitive)
        {
            // If not sensitive, always show content
            IsContentVisible = true;
        }
        // If sensitive, start with content hidden
    }

    private void ShowContent()
    {
        IsContentVisible = true;
    }
}

<style>
    .sensitive-content-gate .alert {
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .sensitive-content-gate .btn-warning {
        font-weight: 600;
    }

    .sensitive-content-gate ul {
        list-style-type: none;
        padding-left: 0;
    }

    .sensitive-content-gate li::before {
        content: "• ";
        color: #ffc107;
    }
</style>
