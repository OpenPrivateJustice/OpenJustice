@page "/cases/create"
@inject IGeneratorApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Novo Caso - AtrocidadesRSS</PageTitle>

<div class="container">
    <nav aria-label="Breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/cases">Casos</a></li>
            <li class="breadcrumb-item active" aria-current="page">Novo Caso</li>
        </ol>
    </nav>

    <h1 class="mb-4">Novo Caso</h1>

    @if (submitError != null)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Erro ao salvar</h4>
            <p>@submitError</p>
            <hr>
            <button class="btn btn-outline-danger" @onclick="() => submitError = null">Tentar novamente</button>
        </div>
    }

    <EditForm Model="@caseForm" OnValidSubmit="HandleValidSubmit" FormName="CaseCreateForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- Crime Details Section -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Detalhes do Crime</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="crimeType" class="form-label">Tipo de Crime *</label>
                        <InputSelect id="crimeType" @bind-Value="caseForm.CrimeTypeId" class="form-select">
                            <option value="0">Selecione...</option>
                            @foreach (var crimeType in LookupData.CrimeTypes)
                            {
                                <option value="@crimeType.Id">@crimeType.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => caseForm.CrimeTypeId)" />
                    </div>
                    <div class="col-md-4">
                        <label for="caseType" class="form-label">Tipo de Caso *</label>
                        <InputSelect id="caseType" @bind-Value="caseForm.CaseTypeId" class="form-select">
                            <option value="0">Selecione...</option>
                            @foreach (var caseType in LookupData.CaseTypes)
                            {
                                <option value="@caseType.Id">@caseType.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => caseForm.CaseTypeId)" />
                    </div>
                    <div class="col-md-4">
                        <label for="judicialStatus" class="form-label">Status Judicial *</label>
                        <InputSelect id="judicialStatus" @bind-Value="caseForm.JudicialStatusId" class="form-select">
                            <option value="0">Selecione...</option>
                            @foreach (var status in LookupData.JudicialStatuses)
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => caseForm.JudicialStatusId)" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label for="crimeDescription" class="form-label">Descrição do Crime</label>
                        <InputTextArea id="crimeDescription" @bind-Value="caseForm.CrimeDescription" class="form-control" rows="4" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="crimeDate" class="form-label">Data do Crime</label>
                        <InputDate id="crimeDate" @bind-Value="caseForm.CrimeDate" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="reportDate" class="form-label">Data da Denúncia</label>
                        <InputDate id="reportDate" @bind-Value="caseForm.ReportDate" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="crimeConfidence" class="form-label">Confiança dos Dados (%)</label>
                        <InputNumber id="crimeConfidence" @bind-Value="caseForm.CrimeConfidence" class="form-control" min="0" max="100" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="locationCity" class="form-label">Cidade</label>
                        <InputText id="locationCity" @bind-Value="caseForm.CrimeLocationCity" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="locationState" class="form-label">Estado</label>
                        <InputText id="locationState" @bind-Value="caseForm.CrimeLocationState" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="locationAddress" class="form-label">Endereço</label>
                        <InputText id="locationAddress" @bind-Value="caseForm.CrimeLocationAddress" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Victim Information Section -->
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Informações da Vítima</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="victimName" class="form-label">Nome</label>
                        <InputText id="victimName" @bind-Value="caseForm.VictimName" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label for="victimGender" class="form-label">Gênero</label>
                        <InputSelect id="victimGender" @bind-Value="caseForm.VictimGender" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="M">Masculino</option>
                            <option value="F">Feminino</option>
                            <option value="Other">Outro</option>
                            <option value="Unknown">Desconhecido</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label for="victimAge" class="form-label">Idade</label>
                        <InputNumber id="victimAge" @bind-Value="caseForm.VictimAge" class="form-control" min="0" max="150" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="victimNationality" class="form-label">Nacionalidade</label>
                        <InputText id="victimNationality" @bind-Value="caseForm.VictimNationality" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="victimProfession" class="form-label">Profissão</label>
                        <InputText id="victimProfession" @bind-Value="caseForm.VictimProfession" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="victimConfidence" class="form-label">Confiança (%)</label>
                        <InputNumber id="victimConfidence" @bind-Value="caseForm.VictimConfidence" class="form-control" min="0" max="100" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Accused Information Section -->
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Informações do Acusado</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="accusedName" class="form-label">Nome</label>
                        <InputText id="accusedName" @bind-Value="caseForm.AccusedName" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label for="accusedGender" class="form-label">Gênero</label>
                        <InputSelect id="accusedGender" @bind-Value="caseForm.AccusedGender" class="form-select">
                            <option value="">Selecione...</option>
                            <option value="M">Masculino</option>
                            <option value="F">Feminino</option>
                            <option value="Other">Outro</option>
                            <option value="Unknown">Desconhecido</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label for="accusedAge" class="form-label">Idade</label>
                        <InputNumber id="accusedAge" @bind-Value="caseForm.AccusedAge" class="form-control" min="0" max="150" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="accusedNationality" class="form-label">Nacionalidade</label>
                        <InputText id="accusedNationality" @bind-Value="caseForm.AccusedNationality" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="accusedProfession" class="form-label">Profissão</label>
                        <InputText id="accusedProfession" @bind-Value="caseForm.AccusedProfession" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="accusedConfidence" class="form-label">Confiança (%)</label>
                        <InputNumber id="accusedConfidence" @bind-Value="caseForm.AccusedConfidence" class="form-control" min="0" max="100" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Judicial Information Section -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Informações Judiciais</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="processNumber" class="form-label">Número do Processo</label>
                        <InputText id="processNumber" @bind-Value="caseForm.ProcessNumber" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="court" class="form-label">Vara/Tribunal</label>
                        <InputText id="court" @bind-Value="caseForm.Court" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="county" class="form-label">Comarca</label>
                        <InputText id="county" @bind-Value="caseForm.County" class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="currentPhase" class="form-label">Fase Atual</label>
                        <InputText id="currentPhase" @bind-Value="caseForm.CurrentPhase" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="judicialConfidence" class="form-label">Confiança (%)</label>
                        <InputNumber id="judicialConfidence" @bind-Value="caseForm.JudicialConfidence" class="form-control" min="0" max="100" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Classification Section -->
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Classificação</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label for="mainCategory" class="form-label">Categoria Principal</label>
                        <InputText id="mainCategory" @bind-Value="caseForm.MainCategory" class="form-control" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-check">
                            <InputCheckbox id="isSensitive" @bind-Value="caseForm.IsSensitiveContent" class="form-check-input" />
                            <label for="isSensitive" class="form-check-label">Conteúdo Sensível</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check">
                            <InputCheckbox id="isVerified" @bind-Value="caseForm.IsVerified" class="form-check-input" />
                            <label for="isVerified" class="form-check-label">Verificado</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mb-5">
            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>Salvando...</span>
                }
                else
                {
                    <span>Salvar Caso</span>
                }
            </button>
            <a href="/cases" class="btn btn-secondary">Cancelar</a>
        </div>
    </EditForm>
</div>

@code {
    private CaseFormModel caseForm = new();
    private bool isSubmitting = false;
    private string? submitError;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        submitError = null;

        try
        {
            var request = caseForm.ToCreateRequest();
            var (result, error) = await ApiClient.CreateCaseAsync(request);

            if (error != null)
            {
                submitError = error;
            }
            else if (result != null)
            {
                Navigation.NavigateTo("/cases");
            }
        }
        catch (Exception ex)
        {
            submitError = $"Erro inesperado: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
