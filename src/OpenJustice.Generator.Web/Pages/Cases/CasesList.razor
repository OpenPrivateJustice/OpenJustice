@page "/cases"
@inject IGeneratorApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Lista de Casos - OpenJustice</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Casos</h1>
        <a href="/cases/create" class="btn btn-primary">
            Novo Caso
        </a>
    </div>

    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Erro</h4>
            <p>@errorMessage</p>
            <hr>
            <button class="btn btn-outline-danger" @onclick="LoadCases">Tentar novamente</button>
        </div>
    }
    else if (cases.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">Nenhum caso encontrado</h4>
            <p>Comece criando um novo caso.</p>
            <hr>
            <a href="/cases/create" class="btn btn-info">Criar primeiro caso</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Código de Referência</th>
                        <th>Tipo de Crime</th>
                        <th>Status Judicial</th>
                        <th>Local</th>
                        <th>Última Atualização</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var caseItem in cases)
                    {
                        <tr>
                            <td>
                                <strong>@caseItem.ReferenceCode</strong>
                            </td>
                            <td>@caseItem.CrimeType?.Name</td>
                            <td>
                                <span class="badge bg-@GetJudicialStatusBadge(caseItem.JudicialStatus?.Name)">
                                    @caseItem.JudicialStatus?.Name
                                </span>
                            </td>
                            <td>
                                @caseItem.CrimeLocationCity@(caseItem.CrimeLocationCity != null && caseItem.CrimeLocationState != null ? ", " : "")@caseItem.CrimeLocationState
                            </td>
                            <td>
                                @caseItem.LastUpdated.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a href="/cases/edit/@caseItem.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                        Editar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Case> cases = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCases();
    }

    private async Task LoadCases()
    {
        isLoading = true;
        errorMessage = null;
        
        try
        {
            cases = await ApiClient.GetAllCasesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar casos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetJudicialStatusBadge(string? statusName)
    {
        return statusName?.ToLower() switch
        {
            "condenado" => "success",
            "em processo" or "processo" => "primary",
            "investigação" or "investigacao" => "warning",
            "arquivado" => "secondary",
            "absolvido" => "info",
            _ => "secondary"
        };
    }
}
